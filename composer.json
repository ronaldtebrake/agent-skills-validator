{
    "name": "ronaldtebrake/agent-skills-validator",
    "description": "PHP validator for Agent Skills SKILL.md files per agentskills.io specification",
    "type": "library",
    "keywords": [
        "agent-skills",
        "validation",
        "skills",
        "agentskills.io"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "symfony/filesystem": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "AgentSkills\\Validator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AgentSkills\\Validator\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
