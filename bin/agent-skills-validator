#!/usr/bin/env php
<?php

require_once __DIR__ . '/../vendor/autoload.php';

use AgentSkills\Validator\Validator;

/**
 * CLI tool to validate Agent Skills in CI/CD environments.
 * 
 * Usage:
 *   php bin/agent-skills-validator [path]
 *   vendor/bin/agent-skills-validator [path]
 * 
 * If a path is provided, it will validate all skills in that directory.
 * If a path is a directory containing SKILL.md, it will be validated directly.
 * If a path is a directory without SKILL.md, it will search for subdirectories containing SKILL.md.
 * If no path is provided, it defaults to the current directory.
 */

$validator = new Validator();
$exitCode = 0;

// Parse arguments - use provided path or default to current directory
$args = array_slice($argv, 1);
$paths = !empty($args) ? $args : [getcwd()];

// Expand directories to discover skill subdirectories
$skillPaths = [];
foreach ($paths as $path) {
    if (!is_dir($path)) {
        echo "Error: Path is not a directory: $path\n";
        $exitCode = 1;
        continue;
    }
    
    // Check if this directory itself is a skill (contains SKILL.md)
    $skillMdPath = $path . '/SKILL.md';
    if (file_exists($skillMdPath)) {
        // This is a skill directory, validate it directly
        $skillPaths[] = $path;
    } else {
        // This is a parent directory, find all skill subdirectories
        $discoveredSkills = discoverSkillDirectories($path);
        if (empty($discoveredSkills)) {
            echo "Warning: No skills found in: $path\n";
        } else {
            $skillPaths = array_merge($skillPaths, $discoveredSkills);
        }
    }
}

// Remove duplicates and sort for consistent output
$skillPaths = array_unique($skillPaths);
sort($skillPaths);

// Validate each skill path
foreach ($skillPaths as $skillPath) {
    $result = $validator->validateSkill($skillPath);
    
    $skillName = basename($skillPath);
    if ($result['valid']) {
        echo "✓ $skillName: Valid\n";
    } else {
        echo "✗ $skillName: Invalid\n";
        foreach ($result['errors'] as $error) {
            echo "  - $error\n";
        }
        $exitCode = 1;
    }
}

exit($exitCode);

/**
 * Discover all skill directories within a given directory.
 * 
 * A skill directory is a subdirectory that contains a SKILL.md file.
 * 
 * @param string $directory
 *   The directory to search in.
 * 
 * @return array
 *   Array of skill directory paths.
 */
function discoverSkillDirectories(string $directory): array {
    $skillPaths = [];
    
    if (!is_dir($directory)) {
        return $skillPaths;
    }
    
    $iterator = new \RecursiveIteratorIterator(
        new \RecursiveDirectoryIterator($directory, \RecursiveDirectoryIterator::SKIP_DOTS),
        \RecursiveIteratorIterator::SELF_FIRST
    );
    
    foreach ($iterator as $item) {
        if ($item->isDir()) {
            $skillMdPath = $item->getPathname() . '/SKILL.md';
            if (file_exists($skillMdPath)) {
                $skillPaths[] = $item->getPathname();
            }
        }
    }
    
    return $skillPaths;
}
