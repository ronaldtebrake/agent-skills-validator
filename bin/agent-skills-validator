#!/usr/bin/env php
<?php

require_once __DIR__ . '/../vendor/autoload.php';

use AgentSkills\Validator\Validator;

/**
 * CLI tool to validate Agent Skills in CI/CD environments.
 * 
 * Usage:
 *   php bin/agent-skills-validator [path1] [path2] ...
 *   php bin/agent-skills-validator validate [path1] [path2] ...  # 'validate' subcommand is optional
 *   php bin/agent-skills-validator --changed  # Validates only changed skills in git
 *   vendor/bin/agent-skills-validator validate [path1] [path2] ...  # When installed via Composer
 */

$validator = new Validator();
$exitCode = 0;
$paths = [];

// Parse arguments
$args = array_slice($argv, 1);

// Handle 'validate' subcommand - ignore it if present as first argument
if (!empty($args) && $args[0] === 'validate') {
    $args = array_slice($args, 1);
}

if (in_array('--changed', $args) || in_array('-c', $args)) {
    // Get changed directories from git
    $paths = getChangedSkillPaths();
    if (empty($paths)) {
        echo "No changed skills found.\n";
        exit(0);
    }
} else {
    // Use provided paths or default to current directory
    $paths = $args;
    if (empty($paths)) {
        $paths = [getcwd()];
    }
}

// Validate each path
foreach ($paths as $path) {
    if (!is_dir($path)) {
        echo "Error: Path is not a directory: $path\n";
        $exitCode = 1;
        continue;
    }
    
    $result = $validator->validateSkill($path);
    
    $skillName = basename($path);
    if ($result['valid']) {
        echo "✓ $skillName: Valid\n";
    } else {
        echo "✗ $skillName: Invalid\n";
        foreach ($result['errors'] as $error) {
            echo "  - $error\n";
        }
        $exitCode = 1;
    }
}

exit($exitCode);

/**
 * Get paths to changed skill directories from git.
 */
function getChangedSkillPaths(): array {
    // Get changed files
    $changedFiles = [];
    exec('git diff --name-only --diff-filter=ACMR HEAD', $changedFiles);
    
    $skillPaths = [];
    foreach ($changedFiles as $file) {
        // If SKILL.md changed, get its directory
        if (basename($file) === 'SKILL.md') {
            $dir = dirname($file);
            if ($dir !== '.' && !in_array($dir, $skillPaths)) {
                $skillPaths[] = $dir;
            }
        }
    }
    
    return $skillPaths;
}
